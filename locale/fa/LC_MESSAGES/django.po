#: nextcloudappstore/user/templates/user/deprecate-apps.html:37
#: nextcloudappstore/user/templates/user/enterprise-apps.html:38
msgid "Mark as supported"
msgstr "علامت‌گذاری به عنوان پشتیبانی شده"

#: nextcloudappstore/user/templates/user/deprecate-apps.html:39
msgid "Mark as deprecated"
msgstr "علامت‌گذاری به عنوان منسوخ"

