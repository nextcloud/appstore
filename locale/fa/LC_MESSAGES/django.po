msgid "Unsupported"
msgstr "بدون پشتیبانی"

#: nextcloudappstore/user/templates/user/enterprise-apps.html:36
msgid "Mark as unsupported"
msgstr "علامت‌گذاری به عنوان بدون پشتیبانی"

